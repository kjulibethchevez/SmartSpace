<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundLight">

    <!-- Logo -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/smartspace_logo"
        android:contentDescription="Logo SmartSpace"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnCamara"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="20dp"/>

    <!-- Botón cámara -->
    <Button
        android:id="@+id/btnCamara"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Tomar Foto"
        android:textColor="@color/white"
        android:background="@drawable/rounded_button"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginTop="30dp"/>

    <!-- Botón galería -->
    <Button
        android:id="@+id/btnGaleria"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Seleccionar Imagen"
        android:textColor="@color/white"
        android:background="@drawable/rounded_button"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/btnCamara"
        app:layout_constraintStart_toStartOf="@id/btnCamara"
        app:layout_constraintEnd_toEndOf="@id/btnCamara"
        android:layout_marginTop="20dp"/>

    <!-- Botón modo en vivo -->
    <Button
        android:id="@+id/btnLive"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Modo en Vivo"
        android:textColor="@color/white"
        android:background="@drawable/rounded_button"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/btnGaleria"
        app:layout_constraintStart_toStartOf="@id/btnGaleria"
        app:layout_constraintEnd_toEndOf="@id/btnGaleria"
        android:layout_marginTop="20dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>